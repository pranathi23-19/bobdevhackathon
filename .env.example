# Application Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# API Configuration
API_PREFIX=/api/v1
API_RATE_LIMIT=100

# Data Sources
LOG_SOURCE=file
LOG_FILE_PATH=./data/logs
LOG_WATCH_INTERVAL=5000

# Git Configuration
GIT_REPO_PATH=./
GIT_BRANCH=main
GIT_ANALYSIS_DEPTH=100
GIT_AUTHOR_EMAIL=

# Code Metrics
CODE_COMPLEXITY_THRESHOLD=10
CODE_COVERAGE_THRESHOLD=80
CODE_DUPLICATION_THRESHOLD=5

# Machine Learning Model Configuration
MODEL_TYPE=neural_network
MODEL_THRESHOLD=0.7
MODEL_TRAINING_EPOCHS=1000
MODEL_LEARNING_RATE=0.01

# Risk Weights (must sum to 1.0)
RISK_WEIGHT_CODE_QUALITY=0.40
RISK_WEIGHT_SYSTEM_LOGS=0.35
RISK_WEIGHT_DEVELOPER_ACTIVITY=0.25

# Risk Thresholds
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=80

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/risk-predictor
MONGODB_OPTIONS=retryWrites=true&w=majority

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3

# Alert Configuration
ENABLE_ALERTS=true
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
EMAIL_ALERTS=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_HEALTH_CHECK=true

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=24h
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# Feature Flags
ENABLE_REAL_TIME_ANALYSIS=true
ENABLE_HISTORICAL_TRENDS=true
ENABLE_TEAM_ANALYTICS=true
ENABLE_AUTO_REMEDIATION=false

# External Integrations
GITHUB_TOKEN=
JIRA_API_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# MongoDB Logs Configuration
MONGODB_LOGS_ENABLED=true
MONGODB_DATABASE=admin
MONGODB_LOGS_COLLECTION=application-logs

# Performance
MAX_CONCURRENT_ANALYSES=10
CACHE_TTL=3600
REQUEST_TIMEOUT=30000

# Development
DEBUG=false
MOCK_DATA=false
SEED_DATABASE=false